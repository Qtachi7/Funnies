<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title).presence || "funnies" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="funnies">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= asset_path('icon/funnies_icon_trimmed.png') %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path('icon/funnies_icon_trimmed.png') %>">

    <%# Tailwind CSS Play CDN – switch to tailwindcss-rails gem for production %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['-apple-system', 'BlinkMacSystemFont', '"Hiragino Sans"', '"Hiragino Kaku Gothic ProN"', 'Meiryo', 'sans-serif']
            }
          }
        }
      }
    </script>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-neutral-50 font-sans min-h-screen">
    <%= render "shared/topbar" %>

    <div class="pb-16 md:pb-0">
      <%= render "shared/flash" if flash.any? %>
      <%= yield %>
    </div>

    <%= render "shared/bottom_nav" %>

  </body>
</html>
