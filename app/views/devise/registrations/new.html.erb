<% content_for :title, "新規登録 – funnies" %>

<div class="min-h-[calc(100vh-4rem)] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">

    <%# ロゴ & キャッチ %>
    <div class="text-center mb-8">
      <%= link_to root_path do %>
        <div class="text-5xl font-bold bg-gradient-to-r from-amber-500 to-orange-500 bg-clip-text text-transparent mb-3">
          funny`s
        </div>
      <% end %>
      <p class="text-lg text-neutral-600">Only fun & positive</p>
      <p class="text-sm text-neutral-500 mt-2">ポジティブで面白いコンテンツだけを共有しよう</p>
    </div>

    <%# カード %>
    <div class="bg-white rounded-2xl border border-neutral-200 shadow-xl overflow-hidden">

      <%# タブ %>
      <div class="flex border-b border-neutral-200">
        <%= link_to new_user_session_path, class: "flex-1 py-4 text-sm font-medium text-center text-neutral-600 hover:bg-neutral-50 transition-colors" do %>
          ログイン / Login
        <% end %>
        <span class="flex-1 py-4 text-sm font-medium text-center text-amber-600 border-b-2 border-amber-600 bg-amber-50/50">
          新規登録 / Sign Up
        </span>
      </div>

      <div class="p-8">
        <%= render "devise/shared/error_messages", resource: resource %>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-2">表示名（オプション）</label>
              <div class="relative">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <%= f.text_field :display_name,
                    placeholder: "ニックネーム",
                    class: "w-full pl-12 pr-4 py-3 border border-neutral-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" %>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-2">
                ユーザーID <span class="text-red-500">*</span>
                <span class="text-xs font-normal text-neutral-400 ml-1">半角英数字・アンダースコア（3〜20文字）</span>
              </label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-neutral-400 font-medium select-none">@</span>
                <%= f.text_field :username,
                    placeholder: "your_id",
                    class: "w-full pl-8 pr-4 py-3 border border-neutral-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" %>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-2">メールアドレス</label>
              <div class="relative">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <%= f.email_field :email,
                    autofocus: true, autocomplete: "email",
                    placeholder: "example@email.com",
                    class: "w-full pl-12 pr-4 py-3 border border-neutral-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" %>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-2">パスワード</label>
              <div class="relative">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
                <%= f.password_field :password,
                    autocomplete: "new-password",
                    placeholder: "6文字以上",
                    class: "w-full pl-12 pr-4 py-3 border border-neutral-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" %>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-neutral-700 mb-2">パスワード（確認）</label>
              <div class="relative">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
                <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    placeholder: "••••••••",
                    class: "w-full pl-12 pr-4 py-3 border border-neutral-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" %>
              </div>
            </div>

            <%= f.submit "アカウント作成",
                class: "w-full py-3 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white rounded-xl font-medium transition-all cursor-pointer" %>
          </div>
        <% end %>

        <p class="mt-4 text-xs text-center text-neutral-500">
          アカウント作成により、<span class="text-amber-600">利用規約</span>および<span class="text-amber-600">プライバシーポリシー</span>に同意したものとみなされます
        </p>
      </div>
    </div>

    <div class="mt-6 text-center">
      <%= link_to root_path, class: "text-sm text-neutral-600 hover:text-neutral-900" do %>
        ← ホームに戻る
      <% end %>
    </div>
  </div>
</div>
