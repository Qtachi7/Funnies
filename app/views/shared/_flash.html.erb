<% flash.each do |type, message| %>
  <% bg = type.to_s == "alert" ? "bg-red-50 border-red-200 text-red-700" : "bg-green-50 border-green-200 text-green-700" %>
  <div class="max-w-[1440px] mx-auto px-4 md:px-8 pt-4">
    <div class="<%= bg %> border rounded-xl px-4 py-3 text-sm flex items-center justify-between">
      <span><%= message %></span>
      <button onclick="this.parentElement.parentElement.remove()" class="ml-4 opacity-60 hover:opacity-100">✕</button>
    </div>
  </div>
<% end %>
