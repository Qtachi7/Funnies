<%# モバイル用ボトムナビ（md以上では非表示）%>
<nav class="fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-neutral-200 md:hidden">
  <div class="flex items-center justify-around px-2 py-2 safe-area-inset-bottom">

    <%= link_to root_path, class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors #{current_page?(root_path) ? 'text-amber-600' : 'text-neutral-500 hover:text-neutral-900'}" do %>
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      <span class="text-[10px] font-medium">ホーム</span>
    <% end %>

    <a href="#" class="flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg text-neutral-400">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
      </svg>
      <span class="text-[10px] font-medium">トレンド</span>
    </a>

    <% if user_signed_in? %>
      <a href="#post-composer" class="flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg text-neutral-500 hover:text-amber-600 transition-colors">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        <span class="text-[10px] font-medium">投稿</span>
      </a>
    <% else %>
      <%= link_to new_user_session_path, class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg text-neutral-500 hover:text-amber-600 transition-colors" do %>
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        <span class="text-[10px] font-medium">投稿</span>
      <% end %>
    <% end %>

    <%= link_to rankings_path, class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors #{current_page?(rankings_path) ? 'text-amber-600' : 'text-neutral-500 hover:text-neutral-900'}" do %>
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
      </svg>
      <span class="text-[10px] font-medium">ランキング</span>
    <% end %>

    <% if user_signed_in? %>
      <%= link_to profile_path, class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors #{current_page?(profile_path) ? 'text-amber-600' : 'text-neutral-500 hover:text-neutral-900'}" do %>
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span class="text-[10px] font-medium">プロフィール</span>
      <% end %>
    <% else %>
      <%= link_to new_user_session_path, class: "flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg text-neutral-500 hover:text-amber-600 transition-colors" do %>
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
        </svg>
        <span class="text-[10px] font-medium">ログイン</span>
      <% end %>
    <% end %>
  </div>
</nav>
