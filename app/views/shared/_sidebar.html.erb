<aside class="hidden lg:block w-64 sticky top-20 h-[calc(100vh-5rem)] overflow-y-auto">
  <nav class="flex flex-col gap-1 py-4">

    <%= link_to root_path,
        class: "flex items-center gap-4 px-6 py-3 rounded-full transition-all #{current_page?(root_path) ? 'bg-amber-50 text-amber-600 font-medium' : 'hover:bg-neutral-100'}" do %>
      <svg class="w-6 h-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      <div class="flex flex-col">
        <span class="text-base">ホーム</span>
        <span class="text-xs text-neutral-400">Home</span>
      </div>
    <% end %>

    <a href="#" class="flex items-center gap-4 px-6 py-3 rounded-full transition-all hover:bg-neutral-100 text-neutral-400">
      <svg class="w-6 h-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
      </svg>
      <div class="flex flex-col">
        <span class="text-base">トレンド</span>
        <span class="text-xs text-neutral-400">Trending</span>
      </div>
    </a>

    <%= link_to rankings_path,
        class: "flex items-center gap-4 px-6 py-3 rounded-full transition-all #{current_page?(rankings_path) ? 'bg-amber-50 text-amber-600 font-medium' : 'hover:bg-neutral-100'}" do %>
      <svg class="w-6 h-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
      </svg>
      <div class="flex flex-col">
        <span class="text-base">ランキング</span>
        <span class="text-xs text-neutral-400">Ranking</span>
      </div>
    <% end %>

    <% if user_signed_in? %>
      <%= link_to profile_path,
          class: "flex items-center gap-4 px-6 py-3 rounded-full transition-all #{current_page?(profile_path) ? 'bg-amber-50 text-amber-600 font-medium' : 'hover:bg-neutral-100'}" do %>
        <svg class="w-6 h-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <div class="flex flex-col">
          <span class="text-base">プロフィール</span>
          <span class="text-xs text-neutral-400">Profile</span>
        </div>
      <% end %>
    <% else %>
      <%= link_to new_user_session_path,
          class: "mt-4 flex items-center justify-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white rounded-full font-medium text-sm transition-all shadow-sm hover:shadow-md" do %>
        ログイン / Login
      <% end %>
    <% end %>
  </nav>
</aside>
