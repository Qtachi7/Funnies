<%# locals: (post:, comment:) %>
<div class="bg-white rounded-2xl border border-neutral-200 overflow-hidden shadow-sm">

  <%# Header — post_card と同じ構造 %>
  <div class="px-6 py-4 flex items-center gap-3">
    <%= link_to user_path(comment.user),
        class: "flex items-center gap-3 flex-1 min-w-0 hover:opacity-80 transition-opacity" do %>
      <% if comment.user.avatar&.attached? %>
        <%= image_tag comment.user.avatar.variant(resize_to_fill: [40, 40]),
            class: "w-10 h-10 rounded-full object-cover flex-shrink-0" %>
      <% else %>
        <div class="w-10 h-10 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">
          <%= comment.user.display_name_or_email.first.upcase %>
        </div>
      <% end %>
      <div class="min-w-0">
        <div class="flex items-baseline gap-1.5 flex-wrap">
          <span class="font-bold text-base"><%= comment.user.display_name_or_email %></span>
          <% if comment.user.username.present? %>
            <span class="text-sm text-neutral-400">@<%= comment.user.username %></span>
          <% end %>
        </div>
        <div class="text-xs text-neutral-500"><%= time_ago_in_words(comment.created_at) %>前</div>
      </div>
    <% end %>
    <% if current_user && comment.user == current_user %>
      <div data-controller="kebab" class="relative flex-shrink-0">
        <button data-action="click->kebab#toggle click@window->kebab#close"
                class="p-2 text-neutral-400 hover:text-neutral-600 hover:bg-neutral-100 rounded-full transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
          </svg>
        </button>
        <div data-kebab-target="menu" class="hidden absolute right-0 top-full mt-1 w-40 bg-white rounded-xl border border-neutral-200 shadow-lg z-50 overflow-hidden">
          <%= button_to post_comment_path(post, comment), method: :delete,
              data: { turbo_confirm: "このコメントを削除しますか？" },
              class: "w-full flex items-center gap-3 px-4 py-3 text-sm text-red-600 hover:bg-red-50 transition-colors" do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            削除
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 本文 %>
  <div class="px-6 pb-4">
    <p class="text-neutral-700 whitespace-pre-wrap break-words"><%= comment.body %></p>
  </div>

  <%# 返信一覧 %>
  <% if comment.replies.any? %>
    <div class="border-t border-neutral-100">
      <% comment.replies.each do |reply| %>
        <div class="flex gap-3 px-6 py-3 border-b border-neutral-50 last:border-0">
          <% if reply.user.avatar&.attached? %>
            <%= image_tag reply.user.avatar.variant(resize_to_fill: [32, 32]),
                class: "w-8 h-8 rounded-full object-cover flex-shrink-0 mt-0.5" %>
          <% else %>
            <div class="w-8 h-8 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">
              <%= reply.user.display_name_or_email.first.upcase %>
            </div>
          <% end %>
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <%= link_to reply.user.display_name_or_email, user_path(reply.user),
                  class: "font-bold text-sm hover:text-amber-600 transition-colors" %>
              <span class="text-xs text-neutral-400"><%= time_ago_in_words(reply.created_at) %>前</span>
            </div>
            <p class="text-sm text-neutral-700 whitespace-pre-wrap break-words"><%= reply.body %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# 返信フォーム（<details> でトグル）%>
  <% if user_signed_in? %>
    <div class="px-6 pb-4 border-t border-neutral-100 pt-3">
      <details class="group">
        <summary class="inline-flex items-center gap-1.5 text-sm text-neutral-500 hover:text-amber-600 cursor-pointer transition-colors list-none">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
          </svg>
          返信する
        </summary>
        <div class="mt-3">
          <%= render "comments/form", post: post, comment: Comment.new(parent_id: comment.id) %>
        </div>
      </details>
    </div>
  <% end %>

</div>
