<%# locals: (post:, comment:) %>
<%= form_with model: [post, comment], class: "flex flex-col gap-2" do |f| %>
  <%= f.hidden_field :parent_id if comment.parent_id.present? %>
  <% if comment.errors.any? %>
    <div class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">
      <% comment.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= f.text_area :body,
      rows: 2,
      maxlength: 1000,
      placeholder: "コメントを入力…",
      class: "w-full resize-none rounded-xl border border-neutral-200 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-transparent" %>

  <div class="flex justify-end">
    <%= f.submit "送信",
        class: "px-5 py-2 bg-gradient-to-r from-amber-500 to-orange-500 text-white text-sm font-bold rounded-full hover:opacity-90 transition-opacity cursor-pointer" %>
  </div>
<% end %>
