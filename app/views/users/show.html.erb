<% content_for :title, "#{@user.display_name_or_email} – funnies" %>

<%# カバー画像 %>
<div class="h-48 md:h-64 overflow-hidden">
  <% if @user.cover.attached? %>
    <%= image_tag @user.cover.variant(resize_to_limit: [1440, 256]), class: "w-full h-full object-cover" %>
  <% else %>
    <div class="w-full h-full bg-gradient-to-br from-amber-400 via-orange-400 to-orange-500"></div>
  <% end %>
</div>

<%# プロフィールコンテナ %>
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

  <%# プロフィールヘッダーカード %>
  <div class="relative -mt-16 sm:-mt-20 mb-8">
    <div class="bg-white rounded-3xl border border-neutral-200 shadow-lg p-6 sm:p-8">
      <div class="flex flex-col sm:flex-row gap-6 items-start">

        <%# アバター %>
        <div class="flex-shrink-0">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar.variant(resize_to_fill: [128, 128]),
                class: "w-24 h-24 sm:w-32 sm:h-32 rounded-full border-4 border-white shadow-lg object-cover" %>
          <% else %>
            <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full border-4 border-white shadow-lg bg-amber-100 flex items-center justify-center">
              <span class="text-4xl sm:text-5xl font-bold text-amber-600">
                <%= @user.display_name_or_email.first.upcase %>
              </span>
            </div>
          <% end %>
        </div>

        <%# プロフィール情報 %>
        <div class="flex-1 min-w-0">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4">
            <div>
              <h1 class="text-2xl sm:text-3xl font-bold mb-1"><%= @user.display_name_or_email %></h1>
              <% if @user.username.present? %>
                <p class="text-neutral-500">@<%= @user.username %></p>
              <% end %>
            </div>
            <%= link_to edit_profile_path,
                class: "inline-flex items-center gap-2 px-6 py-2.5 bg-gradient-to-r from-amber-500 to-orange-500 text-white rounded-full hover:from-amber-600 hover:to-orange-600 transition-all shadow-sm hover:shadow-md text-sm font-medium" do %>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              プロフィールを編集
            <% end %>
          </div>

          <%# bio %>
          <% if @user.bio.present? %>
            <p class="text-neutral-700 leading-relaxed mb-4"><%= @user.bio %></p>
          <% end %>

          <%# 参加日 %>
          <div class="flex items-center gap-2 text-sm text-neutral-600 mb-6">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span><%= @user.created_at.strftime("%-Y年%-m月") %>に参加</span>
          </div>

          <%# 統計 %>
          <div class="flex flex-wrap gap-6 text-sm">
            <div>
              <span class="font-bold"><%= number_with_delimiter(@user.posts.count) %></span>
              <span class="text-neutral-500 ml-1">投稿</span>
            </div>
            <div>
              <span class="font-bold">
                <%= number_with_delimiter(
                  Post::REACTION_KINDS.sum { |k| @user.posts.sum("#{k}_count") }
                ) %>
              </span>
              <span class="text-neutral-500 ml-1">リアクション獲得</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# タブ %>
  <% tabs = [
    { id: "posts",     label: "投稿",        label_en: "Posts",      count: @user.posts.count },
    { id: "reactions", label: "リアクション", label_en: "Reactions",   count: @user.reactions.distinct.count(:post_id) },
    { id: "stats",     label: "統計",        label_en: "Statistics",  count: nil },
  ] %>

  <div class="bg-white rounded-2xl border border-neutral-200 shadow-sm mb-8 overflow-hidden">
    <div class="border-b border-neutral-200">
      <div class="flex">
        <% tabs.each do |tab| %>
          <%= link_to profile_path(tab: tab[:id]),
              class: "flex-1 px-6 py-4 text-center transition-all relative #{@tab == tab[:id] ? 'text-amber-600' : 'text-neutral-600 hover:text-neutral-900 hover:bg-neutral-50'}" do %>
            <div class="flex flex-col items-center gap-1">
              <span class="font-medium">
                <%= tab[:label] %>
                <% if tab[:count] && tab[:count] > 0 %>
                  <span class="ml-1 text-xs bg-neutral-100 text-neutral-600 px-1.5 py-0.5 rounded-full"><%= tab[:count] %></span>
                <% end %>
              </span>
              <span class="text-xs text-neutral-400"><%= tab[:label_en] %></span>
            </div>
            <% if @tab == tab[:id] %>
              <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-amber-500 to-orange-500"></div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="p-6 sm:p-8">

      <%# 投稿タブ %>
      <% if @tab == "posts" %>
        <% if @posts.any? %>
          <div class="space-y-6">
            <% @posts.each do |post| %>
              <%= render "posts/post_card", post: post %>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-16">
            <div class="w-20 h-20 bg-neutral-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl">📝</span>
            </div>
            <h3 class="text-lg font-bold text-neutral-900 mb-2">まだ投稿がありません</h3>
            <p class="text-neutral-500 text-sm">最初の投稿をシェアしましょう！</p>
            <%= link_to root_path, class: "mt-4 inline-block px-6 py-2.5 bg-gradient-to-r from-amber-500 to-orange-500 text-white rounded-full text-sm font-medium" do %>
              投稿する
            <% end %>
          </div>
        <% end %>

      <%# リアクションタブ %>
      <% elsif @tab == "reactions" %>
        <% if @reacted_posts.any? %>
          <div class="space-y-6">
            <% @reacted_posts.each do |post| %>
              <%= render "posts/post_card", post: post,
                  user_reacted_kinds: @user_reactions[post.id] || Set.new %>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-16">
            <div class="w-20 h-20 bg-neutral-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl">😄</span>
            </div>
            <h3 class="text-lg font-bold text-neutral-900 mb-2">まだリアクションしていません</h3>
            <p class="text-neutral-500 text-sm">気に入った投稿にリアクションしてみましょう！</p>
            <%= link_to root_path, class: "mt-4 inline-block px-6 py-2.5 bg-gradient-to-r from-amber-500 to-orange-500 text-white rounded-full text-sm font-medium" do %>
              タイムラインを見る
            <% end %>
          </div>
        <% end %>

      <%# 統計タブ %>
      <% elsif @tab == "stats" %>
        <div class="space-y-8">

          <%# 概要カード %>
          <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-2xl p-6 border border-amber-200">
              <div class="text-3xl mb-2">📊</div>
              <div class="text-2xl font-bold text-neutral-900"><%= number_with_delimiter(@user.posts.count) %></div>
              <div class="text-sm text-neutral-600">総投稿数</div>
            </div>
            <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl p-6 border border-blue-200">
              <div class="text-3xl mb-2">💫</div>
              <div class="text-2xl font-bold text-neutral-900"><%= number_with_delimiter(@total_reactions) %></div>
              <div class="text-sm text-neutral-600">総リアクション数</div>
            </div>
            <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-2xl p-6 border border-green-200 col-span-2 lg:col-span-1">
              <div class="text-3xl mb-2">📈</div>
              <div class="text-2xl font-bold text-neutral-900">
                <%= @user.posts.count > 0 ? number_with_delimiter(@total_reactions / @user.posts.count) : 0 %>
              </div>
              <div class="text-sm text-neutral-600">平均リアクション数</div>
            </div>
          </div>

          <%# リアクション内訳 %>
          <% if @total_reactions > 0 %>
            <div>
              <h3 class="text-lg font-bold mb-4">リアクションの内訳</h3>
              <% reaction_icons = { "funny" => "😄", "laugh" => "😂", "cry" => "😭", "wow" => "😲", "cool" => "😎", "cute" => "🥰", "surprised" => "😱" } %>
              <% reaction_labels = { "funny" => "面白い", "laugh" => "笑える", "cry" => "泣ける", "wow" => "すごい", "cool" => "かっこいい", "cute" => "かわいい", "surprised" => "びっくり" } %>
              <div class="space-y-3">
                <% @reaction_totals.each do |r| %>
                  <div class="bg-neutral-50 rounded-xl p-4">
                    <div class="flex items-center justify-between mb-2">
                      <div class="flex items-center gap-3">
                        <span class="text-2xl"><%= reaction_icons[r[:kind]] %></span>
                        <span class="font-medium text-neutral-900"><%= reaction_labels[r[:kind]] %></span>
                      </div>
                      <span class="font-bold text-neutral-900"><%= number_with_delimiter(r[:count]) %></span>
                    </div>
                    <div class="bg-white rounded-full h-2 overflow-hidden">
                      <div class="h-full bg-gradient-to-r from-amber-400 to-orange-500 rounded-full transition-all"
                           style="width: <%= @total_reactions > 0 ? (r[:count].to_f / @total_reactions * 100).round(1) : 0 %>%">
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# 活動概要 %>
          <div>
            <h3 class="text-lg font-bold mb-4">活動概要</h3>
            <div class="bg-neutral-50 rounded-xl p-6 space-y-4">
              <div class="flex justify-between items-center">
                <span class="text-neutral-600">今月の投稿数</span>
                <span class="font-medium"><%= @user.posts.monthly.count %> 投稿</span>
              </div>
              <% most_popular = @user.posts.max_by(&:total_reactions) %>
              <% if most_popular %>
                <div class="flex justify-between items-center gap-4">
                  <span class="text-neutral-600 whitespace-nowrap">最も人気の投稿</span>
                  <span class="font-medium text-right line-clamp-1">
                    <%= most_popular.title.presence || most_popular.url.truncate(40) %>
                  </span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    </div>
  </div>

</div>
