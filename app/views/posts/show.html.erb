<% content_for :title, "#{@post.title.presence || 'Post'} – funnies" %>

<div class="max-w-4xl mx-auto px-4 md:px-8 py-6">

  <%# 戻るボタン %>
  <%= link_to root_path, class: "inline-flex items-center gap-2 text-sm text-neutral-600 hover:text-neutral-900 mb-6" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    戻る
  <% end %>

  <article class="bg-white rounded-2xl border border-neutral-200 overflow-hidden shadow-lg">

    <%# Header — post_card と同じ構造 %>
    <div class="px-6 md:px-8 py-4 border-b border-neutral-200 flex items-center gap-3">
      <%= link_to (@post.user ? user_path(@post.user) : "#"),
          class: "flex items-center gap-3 flex-1 min-w-0 hover:opacity-80 transition-opacity" do %>
        <% if @post.user&.avatar&.attached? %>
          <%= image_tag @post.user.avatar.variant(resize_to_fill: [40, 40]),
              class: "w-10 h-10 rounded-full object-cover flex-shrink-0" %>
        <% else %>
          <div class="w-10 h-10 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">
            <%= @post.author_name.first.upcase %>
          </div>
        <% end %>
        <div class="min-w-0">
          <div class="font-bold text-base"><%= @post.author_name %></div>
          <div class="text-xs text-neutral-500"><%= time_ago_in_words(@post.created_at) %>前</div>
        </div>
      <% end %>
      <% if @post.user %>
        <%= render "follows/follow_button", user: @post.user %>
      <% end %>
      <a href="<%= @post.url %>" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-2 px-4 py-2 bg-neutral-100 hover:bg-neutral-200 rounded-full text-sm font-medium transition-colors flex-shrink-0">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
        元のページを見る
      </a>
    </div>

    <%# 本文 — post_card と同じ構造（埋め込みより上）%>
    <% if @post.body.present? %>
      <div class="px-6 py-4">
        <p class="text-lg text-neutral-800"><%= @post.body %></p>
      </div>
    <% end %>

    <%# メディア埋め込み（詳細ページ：フル埋め込み対応）%>
    <%= render "posts/embed", post: @post, card: false %>

    <%# Reactions — post_card と同じパーシャル %>
    <div class="px-6 pb-4" id="reactions-<%= @post.id %>">
      <%= render "posts/reactions", post: @post, user_reacted_kinds: @user_reacted_kinds %>
    </div>

    <%# コメント %>
    <div id="comments" class="px-6 md:px-8 py-6">
      <%= turbo_frame_tag "comments-#{@post.id}" do %>
        <h2 class="font-bold mb-4">
          コメント
          <span class="text-sm font-normal text-neutral-500 ml-1">(<%= @post.comments_count %>)</span>
        </h2>

        <%# 一覧 %>
        <div class="space-y-4 mb-6">
          <% if @comments.empty? %>
            <p class="text-sm text-neutral-400 text-center py-4">まだコメントはありません</p>
          <% else %>
            <% @comments.each do |comment| %>
              <%= render "comments/comment", post: @post, comment: comment %>
            <% end %>
          <% end %>
        </div>

        <%# フォーム %>
        <% if user_signed_in? %>
          <%= render "comments/form", post: @post, comment: Comment.new %>
        <% else %>
          <p class="text-sm text-neutral-500 text-center">
            <%= link_to "ログイン", new_user_session_path, class: "text-amber-600 hover:underline" %>するとコメントできます
          </p>
        <% end %>
      <% end %>
    </div>
  </article>
</div>
