<%# ログインユーザーのみ表示 %>
<% if user_signed_in? %>
  <div class="bg-white rounded-2xl border border-neutral-200 p-6 shadow-sm mb-6" id="post-composer">
    <div class="flex items-center gap-3 mb-4">
      <div>
        <h3 class="font-bold">面白いコンテンツをシェア</h3>
        <p class="text-xs text-neutral-500">Share Funny Content</p>
      </div>
    </div>

    <%= form_with model: @post, url: posts_path, data: { turbo: false } do |f| %>
      <div class="space-y-4">
        <div>
          <div class="relative">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
            </svg>
            <%= f.url_field :url,
                placeholder: "X / Instagram / YouTube / TikTok / ニコニコ動画のURLを入力...",
                required: true,
                class: "w-full pl-12 pr-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all text-sm" %>
          </div>
          <% if @post&.errors&.full_messages_for(:url).any? %>
            <p class="mt-1 text-xs text-red-500"><%= @post.errors.full_messages_for(:url).first %></p>
          <% end %>
        </div>

        <div>
          <%= f.text_area :body,
              placeholder: "コメントを追加（オプション）",
              rows: 3,
              class: "w-full px-4 py-3 bg-neutral-50 border border-neutral-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all resize-none text-sm" %>
        </div>

        <div class="flex justify-end">
          <%= f.submit "投稿する",
              class: "px-8 py-2.5 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white rounded-full text-sm font-medium transition-all shadow-sm hover:shadow-md cursor-pointer" %>
        </div>
      </div>
    <% end %>

    <div class="mt-4 pt-4 border-t border-neutral-100">
      <p class="text-xs text-neutral-500 flex items-start gap-2">
        <span class="text-amber-600">💡</span>
        <span>ポジティブで面白いコンテンツのみを投稿してください。不適切なコンテンツは削除される場合があります。</span>
      </p>
    </div>
  </div>
<% else %>
  <div class="bg-white rounded-2xl border border-neutral-200 p-6 shadow-sm mb-6 text-center">
    <div class="text-4xl mb-3">😄</div>
    <h3 class="font-bold mb-1">面白いコンテンツをシェアしよう！</h3>
    <p class="text-sm text-neutral-500 mb-4">投稿するにはログインが必要です</p>
    <%= link_to new_user_session_path,
        class: "inline-block px-6 py-2.5 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white rounded-full text-sm font-medium transition-all" do %>
      ログイン / Login
    <% end %>
  </div>
<% end %>
