<%# locals: (post:, user_reacted_kinds: Set.new, show_follow_button: true) %>
<article class="bg-white rounded-2xl border border-neutral-200 overflow-hidden hover:border-neutral-300 transition-all shadow-sm hover:shadow-md">

  <%# Header %>
  <div class="px-6 py-4 flex items-center gap-3">
    <%= link_to (post.user ? user_path(post.user) : "#"),
        class: "flex items-center gap-3 flex-1 min-w-0 hover:opacity-80 transition-opacity" do %>
      <% if post.user&.avatar&.attached? %>
        <%= image_tag post.user.avatar.variant(resize_to_fill: [40, 40]), class: "w-10 h-10 rounded-full object-cover flex-shrink-0" %>
      <% else %>
        <div class="w-10 h-10 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">
          <%= post.author_name.first.upcase %>
        </div>
      <% end %>
      <div class="min-w-0">
        <div class="flex items-baseline gap-1.5 flex-wrap">
          <span class="font-bold text-base"><%= post.author_name %></span>
          <% if post.user&.username.present? %>
            <span class="text-sm text-neutral-400">@<%= post.user.username %></span>
          <% end %>
        </div>
        <div class="text-xs text-neutral-500"><%= time_ago_in_words(post.created_at) %>前</div>
      </div>
    <% end %>
    <% if show_follow_button && post.user %>
      <%= render "follows/follow_button", user: post.user %>
    <% end %>
    <div data-controller="kebab" data-kebab-url-value="<%= post_url(post) %>" class="relative flex-shrink-0">
      <button data-action="click->kebab#toggle click@window->kebab#close"
              class="p-2 text-neutral-400 hover:text-neutral-600 hover:bg-neutral-100 rounded-full transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
        </svg>
      </button>
      <div data-kebab-target="menu" class="hidden absolute right-0 top-full mt-1 w-48 bg-white rounded-xl border border-neutral-200 shadow-lg z-50 overflow-hidden">
        <button data-action="click->kebab#copyLink"
                class="w-full flex items-center gap-3 px-4 py-3 text-sm text-neutral-700 hover:bg-neutral-50 transition-colors">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
          リンクをコピー
        </button>
        <% if current_user && post.user == current_user %>
          <%= button_to post_path(post), method: :delete,
              data: { turbo_confirm: "この投稿を削除しますか？" },
              class: "w-full flex items-center gap-3 px-4 py-3 text-sm text-red-600 hover:bg-red-50 transition-colors" do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            削除
          <% end %>
        <% end %>
      </div>
    </div>
  </div>


  <%# Content %>
  <div class="px-6 py-4">
    <% if post.body.present? %>
      <h3 class="text-lg mb-2 hover:text-amber-600 transition-colors line-clamp-2">
        <%= post.body %>
      </h3>
    <% end %>
  </div>
  <%# メディア埋め込み（YouTube/Niconico は iframe、その他はリンクカード）%>
  <%= render "posts/embed", post: post, card: true %>
  <%# Reactions %>
  <div class="px-6 pb-4">
    <div id="reactions-<%= post.id %>">
      <%= render "posts/reactions", post: post, user_reacted_kinds: user_reacted_kinds %>
    </div>
  </div>

  <%# コメント件数 %>
  <div class="px-6 pb-4">
    <%= link_to post_path(post, anchor: "comments"),
        class: "inline-flex items-center gap-1.5 text-sm text-neutral-500 hover:text-amber-600 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <%= post.comments_count %>件のコメント
    <% end %>
  </div>
</article>
