<%# locals: (post:) %>
<%# iframe 非対応・カード表示用のリンクプレビュー %>

<a href="<%= post.url %>" target="_blank" rel="noopener noreferrer" class="block group">
  <div class="relative bg-neutral-100 group-hover:bg-neutral-200 transition-colors flex items-center justify-center" style="aspect-ratio:16/9">
    <div class="text-center p-6">
      <div class="text-5xl mb-3"><%= post.source_icon %></div>
      <p class="text-sm text-neutral-500 line-clamp-2 break-all px-4"><%= post.url.truncate(80) %></p>
      <span class="mt-4 inline-flex items-center gap-1.5 px-4 py-2 bg-white rounded-full text-xs font-medium text-amber-600 border border-amber-200 shadow-sm group-hover:shadow-md transition-all">
        <%= post.source_name %>で見る
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </span>
    </div>
  </div>
</a>
