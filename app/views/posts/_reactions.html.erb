<%# locals: (post:, size: :normal) %>
<% reactions = [
  { key: "funny",     label: "面白い",    icon: "😄" },
  { key: "laugh",     label: "笑える",    icon: "😂" },
  { key: "cry",       label: "泣ける",    icon: "😭" },
  { key: "wow",       label: "すごい",    icon: "😲" },
  { key: "cool",      label: "かっこいい", icon: "😎" },
  { key: "cute",      label: "かわいい",  icon: "🥰" },
  { key: "surprised", label: "びっくり",  icon: "😱" },
] %>

<div class="flex flex-wrap gap-2">
  <% reactions.each do |r| %>
    <%= button_to post_reactions_path(post, kind: r[:key]),
        method: :post,
        data: { turbo_stream: true },
        class: "group flex items-center gap-2 px-3 py-1.5 rounded-full border border-neutral-200 hover:border-amber-300 hover:bg-amber-50 transition-all text-sm",
        id: "reaction-btn-#{post.id}-#{r[:key]}" do %>
      <span class="text-base group-hover:scale-110 transition-transform"><%= r[:icon] %></span>
      <span class="font-medium" id="reaction-count-#{post.id}-#{r[:key]}">
        <%= number_with_delimiter(post.reaction_count(r[:key])) %>
      </span>
    <% end %>
  <% end %>
</div>
